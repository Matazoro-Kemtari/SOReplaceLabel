<metro:MetroWindow 
    x:Class="SOReplaceLabel.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:SOReplaceLabel"
    xmlns:vm="clr-namespace:SOReplaceLabel.ViewModel"
    xmlns:metro="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    
    mc:Ignorable="d"
    
    Icon="label.ico"
    ShowTitleBar ="True"
    ShowIconOnTitleBar="True"
    Title="SOラベル作成"
    Height="800" Width="480"
    MinHeight="480" MinWidth="300">

    <Border Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="3">
                <Button Content="変更" DockPanel.Dock="Left" Command="{Binding SelectWatcherFileCommand}"/>
                <TextBox 
                Name="CheckFilePath"
                Margin="3"
                IsReadOnly="True" TextWrapping="Wrap"
                Style="{StaticResource MaterialDesignFilledTextBox}"
                materialDesign:HintAssist.Hint="変更状態監視ファイル"
                Text= "{Binding WatchFilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </DockPanel>

            <StackPanel Grid.Row="1" Margin="3" Orientation="Horizontal">
                <Button Name="WatchStartButton" Margin="3" Content="監視開始"
                        Command="{Binding StartWatcherCommand}"/>
                <Button Name="WatchEndButton" Margin="3" Content="監視停止"
                        Command="{Binding StopWatcherCommand}"/>
            </StackPanel>

            <TextBox
                Name="LabelText" Grid.Row="2" Margin="3"     
                IsReadOnly="True"
                Style="{StaticResource MaterialDesignFilledTextBox}"
                materialDesign:HintAssist.Hint="ラベルテキスト"
                materialDesign:HintAssist.FloatingScale="0.4"
                FontSize="36" FontWeight="Bold"
                TextAlignment="Center"
                Text="{Binding LabelPreviewText,  Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            <DataGrid Name="datagrid" Grid.Row="3"
                  materialDesign:DataGridAssist.CellPadding="0"
                  materialDesign:DataGridAssist.ColumnHeaderPadding="3" IsReadOnly="True"
                  ItemsSource="{Binding LogMessages, Mode=OneWay}"
                  AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding Date, StringFormat=\{0:MM/dd HH:mm:ss\}}" ClipboardContentBinding="{x:Null}" Header="日付" HeaderStringFormat="" CanUserSort="False"/>
                    <DataGridTextColumn Binding="{Binding Message}" ClipboardContentBinding="{x:Null}" Header="ログ" HeaderStringFormat="" CanUserSort="False"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</metro:MetroWindow>
